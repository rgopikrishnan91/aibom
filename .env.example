# ============================================================
# BOM Tools - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values you need.
#   cp .env.example .env
#
# Only the LLM provider you choose needs its key set.
# All other variables are optional.
# ============================================================

# --- LLM Provider (pick ONE) --------------------------------

# Option 1: OpenAI (default)
# OPENAI_API_KEY=sk-...

# Option 2: OpenRouter (recommended for free/open models)
# OPENROUTER_API_KEY=sk-or-...

# Option 3: Ollama (local, free, no key needed)
# OLLAMA_BASE_URL=http://localhost:11434/v1/

# --- Source API Tokens (optional but recommended) -----------

# GitHub - increases API rate limits (60/hr → 5000/hr)
# Get one at: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_...

# HuggingFace - required for private/gated models
# Get one at: https://huggingface.co/settings/tokens
# HUGGINGFACE_TOKEN=hf_...

# --- Link Fallback (optional) ------------------------------

# Gemini API key for automatic link discovery
# Get one at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AI...

# --- Server Configuration (optional) -----------------------

# BOM_HOST=127.0.0.1
# BOM_PORT=5000

# --- Advanced / Debug (optional) ---------------------------

# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DEBUG_FALLBACK=false
# TEST_CONNECTION=false
# CHECK_NETWORK=true
